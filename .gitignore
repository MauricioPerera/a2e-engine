node_modules/
**/node_modules/
**/dist/
**/out/
**/full-catalog/
**/community-catalog/
**/community-pieces/
**/custom-pieces*/dist/
**/.cursors/
*.log
.DS_Store

# run-history artifacts (OKF+git logger) and temp verify runs
**/.run-history/
.run-history/
**/verify-runs-*/

# workflow registry repo (OKF+git workflow store) — never commit nested
**/.workflow-registry/
.workflow-registry/

# knowledge base repo (OKF+git knowledge store) — never commit nested
**/.knowledge-base/
.knowledge-base/

# catalog-summary.json is a GENERATED artifact (710 pieces, rebuilt by build-catalog-summary.mjs from full-catalog)
**/catalog-summary.json
catalog-summary.json

# durable file-backed backend data artifacts — NEVER commit
**/.data/
.data/
**/vault.json
**/store.json

# SQLite durable backend artifacts — NEVER commit
*.db
**/*.db
**/*.db-journal
*.db-journal
**/*.db-wal
*.db-wal
**/*.db-shm
*.db-shm

# piece-source-manager: custom workdir for discover() clones (default is os.tmpdir(), outside repo)
**/.psm-workdir/

# piece-validator: staging dir (if ever used)
**/.piece-validator-stage/
.piece-validator-stage/

# T2 build sandbox (bwrap): outRoot/tmp dirs the sandbox or smoke scripts write.
# Default outRoot is os.tmpdir() (outside repo), but if someone passes an
# outRoot inside the repo, ignore the generated build/cat/evil temp dirs so no
# untrusted bundle, metadata.json, or exfil artifact ever gets committed.
**/t2-build-*/
**/t2-cat-*/
**/sbx-base-*/
**/sbx-sandbox-*/
**/sbx-evil-src-*/
**/sbx-evil-out-*/
**/sbxmeta-a-out-*/
**/sbxmeta-a-cat-*/
**/sbxmeta-evil-src-*/
**/sbxmeta-evil-out-*/
# host secret written by smoke-sandbox*.mjs during the malicious-piece test
SECRET.txt
